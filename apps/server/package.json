{
  "name": "server",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.mjs",
    "test": "vitest run --maxWorkers=1",
    "worker": "tsx src/worker.ts",
    "worker:once": "tsx src/worker.ts --once"
  },
  "dependencies": {
    "@cipher-atlas/api": "workspace:*",
    "@cipher-atlas/auth": "workspace:*",
    "@cipher-atlas/db": "workspace:*",
    "@cipher-atlas/env": "workspace:*",
    "@fastify/cors": "^11.0.1",
    "@hono/trpc-server": "^0.4.0",
    "@trpc/server": "catalog:",
    "better-auth": "catalog:",
    "drizzle-orm": "catalog:",
    "dotenv": "catalog:",
    "fastify": "^5.3.3",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@cipher-atlas/config": "workspace:*",
    "@types/node": "^22.13.14",
    "tsdown": "^0.21.9",
    "tsx": "^4.19.2",
    "typescript": "catalog:",
    "vitest": "^4.1.9"
  }
}
